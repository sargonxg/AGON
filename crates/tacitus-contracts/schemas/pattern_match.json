{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacitus.me/schemas/v0/pattern_match.json",
  "title": "PatternMatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pattern_id",
    "pattern_version",
    "public_name",
    "taxonomy",
    "actors_involved",
    "evidence_spans",
    "raw_signals",
    "raw_confidence",
    "explanation"
  ],
  "properties": {
    "pattern_id": { "type": "string", "minLength": 1 },
    "pattern_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "public_name": { "type": "string", "minLength": 1 },
    "taxonomy": { "enum": ["escalation", "negotiation", "coalition", "institutional", "linguistic"] },
    "actors_involved": { "type": "array", "items": { "type": "string" } },
    "evidence_spans": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://tacitus.me/schemas/v0/evidence_span.json" }
    },
    "raw_signals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["detector_id", "detector_version", "value", "features"],
        "properties": {
          "detector_id": { "type": "string" },
          "detector_version": { "type": "string" },
          "value": { "type": "number" },
          "features": {}
        }
      }
    },
    "raw_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "calibrated_confidence_bin": {
      "type": ["string", "null"],
      "enum": ["low", "medium", "high", "very_high", null]
    },
    "explanation": { "type": "string" }
  }
}
