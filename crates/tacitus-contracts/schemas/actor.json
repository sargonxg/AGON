{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacitus.me/schemas/v0/actor.json",
  "title": "Actor",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "canonical_label", "aliases", "provenance"],
  "properties": {
    "id": { "type": "string", "pattern": "^actor:[a-z0-9_-]+$" },
    "canonical_label": { "type": "string", "minLength": 1 },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "role": { "type": ["string", "null"] },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://tacitus.me/schemas/v0/evidence_span.json" }
    }
  }
}
