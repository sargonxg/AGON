# AGON local dev environment variables.
# Copy to .env.local (gitignored) and fill in.
# Production: use GCP Secret Manager — see docs/EXTERNALS.md.

# GCP
GCP_PROJECT_ID=tacitus-agon-dev
GCP_REGION=us-central1
ENV=dev
GITHUB_OWNER=sargonxg
GITHUB_REPO=AGON
TF_BUCKET_NAME=tacitus-agon-dev-terraform-state
LOG_LEVEL=info

# HuggingFace — for ONNX model downloads (BGE-M3, DeBERTa, fastcoref).
# Stored in Secret Manager as `hf-token`. Local dev:
#   export HF_TOKEN=$(gcloud secrets versions access latest --secret=hf-token --project=tacitus-agon-dev)
HF_TOKEN=

# Anthropic — for Claude cross-validation (PROMPT 06+).
# Stored in Secret Manager as `anthropic-api-key`.
ANTHROPIC_API_KEY=

# OpenAI — for strict-schema escalation (PROMPT 06+).
# Stored in Secret Manager as `openai-api-key`.
OPENAI_API_KEY=

# Vertex AI auth: uses Application Default Credentials. No key here.
# Run: gcloud auth application-default login --quota-project=tacitus-agon-dev

# Local Postgres (only when not using Cloud SQL)
DATABASE_URL=postgres://agon:agon@localhost:5432/agon
